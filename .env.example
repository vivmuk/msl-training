# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit real keys.

# ── HeyGen ────────────────────────────────────────────────────────────────────
# Enables SDK mode: full-duplex voice, avatar video stream, AND both-sides
# transcript (AVATAR_TALKING_MESSAGE + USER_TALKING_MESSAGE events).
# Without this key the app falls back to iframe embeds (no text capture).
# Get your key at: https://app.heygen.com/settings?nav=API
REACT_APP_HEYGEN_API_KEY=

# ── Venice AI ─────────────────────────────────────────────────────────────────
# Used for two things:
#   1. STT  — live user-speech transcript in iframe fallback mode
#              POST https://api.venice.ai/api/v1/audio/transcriptions
#   2. LLM  — post-session performance analysis (Venice chat completions)
#              POST https://api.venice.ai/api/v1/chat/completions
# Get your key at: https://venice.ai/settings/api
REACT_APP_VENICE_API_KEY=

# LLM model used for post-session analysis (Venice chat completions).
# Defaults to llama-3.3-70b — override if you have access to a different model.
REACT_APP_VENICE_MODEL=llama-3.3-70b
