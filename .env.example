# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit real keys.

# Venice AI — speech-to-text for live transcript capture
# Get your key at: https://venice.ai/settings/api
REACT_APP_VENICE_API_KEY=

# Anthropic — Claude powers post-session performance analysis
# Get your key at: https://console.anthropic.com/
REACT_APP_ANTHROPIC_API_KEY=
